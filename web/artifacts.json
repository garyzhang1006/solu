{
  "dataset": {
    "name": "ESOL / Delaney (MoleculeNet)",
    "n": 1128,
    "target": "log10 aqueous solubility (mol/L)",
    "citation": "Delaney, J.S. ESOL: Estimating Aqueous Solubility Directly from Molecular Structure. J. Chem. Inf. Comput. Sci. 2004."
  },
  "features": [
    {
      "key": "clogp",
      "js_key": "CrippenClogP",
      "label": "LogP (lipophilicity)",
      "unit": "",
      "note": "Higher = more 'oily' / less water-friendly. Pushes solubility DOWN."
    },
    {
      "key": "amw",
      "js_key": "amw",
      "label": "Molecular weight",
      "unit": "g/mol",
      "note": "Bigger molecules are generally harder to dissolve."
    },
    {
      "key": "tpsa",
      "js_key": "tpsa",
      "label": "Polar surface area",
      "unit": "A^2",
      "note": "More polar surface = more water contact. Pushes solubility UP."
    },
    {
      "key": "hbd",
      "js_key": "NumHBD",
      "label": "H-bond donors",
      "unit": "",
      "note": "Groups that donate H-bonds to water (e.g. -OH, -NH). Raise solubility."
    },
    {
      "key": "hba",
      "js_key": "NumHBA",
      "label": "H-bond acceptors",
      "unit": "",
      "note": "Atoms that accept H-bonds from water (e.g. O, N). Raise solubility."
    },
    {
      "key": "rotb",
      "js_key": "NumRotatableBonds",
      "label": "Rotatable bonds",
      "unit": "",
      "note": "Flexibility; weakly linked to solubility."
    },
    {
      "key": "aromrings",
      "js_key": "NumAromaticRings",
      "label": "Aromatic rings",
      "unit": "",
      "note": "Flat hydrophobic rings (like benzene). Tend to lower solubility."
    },
    {
      "key": "fcsp3",
      "js_key": "FractionCSP3",
      "label": "Fraction sp3 C",
      "unit": "",
      "note": "Share of 3D (saturated) carbons; more 3D often dissolves better."
    },
    {
      "key": "rings",
      "js_key": "NumRings",
      "label": "Ring count",
      "unit": "",
      "note": "Total rings in the structure."
    }
  ],
